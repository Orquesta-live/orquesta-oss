# Orquesta OSS — Environment Variables
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — zero setup)
DATABASE_URL="file:./data/orquesta.db"

# Postgres (swap in when ready)
# DATABASE_URL="postgresql://user:password@localhost:5432/orquesta"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Signs sessions — generate your own, never reuse this file's value:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000
